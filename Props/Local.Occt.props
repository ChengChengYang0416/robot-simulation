<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <OcctRoot>$(MSBuildThisFileDirectory)..\Occt\opencascade-7.9.3-vc14-64</OcctRoot>
    <OcctThirdPartyRoot>$(MSBuildThisFileDirectory)..\Occt\3rdparty-vc14-64</OcctThirdPartyRoot>
