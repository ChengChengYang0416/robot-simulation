<Window x:Class="Hmi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:ctl="clr-namespace:Hmi.Controls"
        Title="RobotSimulation" Height="700" Width="1100" MinHeight="700" MinWidth="1100">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Import Model" Click="BtnOpenFolder_Click"/>
                <MenuItem Header="Clear Scene" Click="BtnClear_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MenuIso" Header="ISO" IsCheckable="True" IsChecked="True" Click="BtnIso_Click"/>
                <MenuItem Name="MenuTop" Header="Top" IsCheckable="True" Click="BtnTop_Click"/>
                <Separator/>
                <MenuItem Header="Fit All" Click="BtnFitAll_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar Name="StatusBarMain" DockPanel.Dock="Bottom" Background="#4CAF50">
            <StatusBarItem HorizontalContentAlignment="Center" HorizontalAlignment="Stretch">
                <TextBlock Name="TxtStatus" TextWrapping="Wrap" Foreground="White" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Background="#F3F4F6" LastChildFill="True">
                <ctl:StatusDashboard x:Name="Dashboard" DockPanel.Dock="Bottom" Margin="12,0,12,12"/>

                <TabControl Margin="8" SelectionChanged="ModeTab_SelectionChanged" Name="ModeTabs">
                    <!-- ====== Manual Mode (JOG via press-and-hold buttons) ====== -->
                    <TabItem Header="Manual">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <GroupBox Header="Joint JOG (press &amp; hold)" Margin="0,0,0,12">
                                    <Grid Margin="10,4">
                                        <Grid.Resources>
                                            <Style TargetType="Button" x:Key="JogBtn">
                                                <Setter Property="Width" Value="44"/>
                                                <Setter Property="Height" Value="22"/>
                                                <Setter Property="Margin" Value="6,1"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Focusable" Value="False"/>
                                            </Style>
                                        </Grid.Resources>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="J1"/>
                                        <Button    Grid.Row="0" Grid.Column="1" Content="-" Tag="0:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="0" Grid.Column="2" Content="+" Tag="0:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="J2"/>
                                        <Button    Grid.Row="1" Grid.Column="1" Content="-" Tag="1:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="1" Grid.Column="2" Content="+" Tag="1:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="J3"/>
                                        <Button    Grid.Row="2" Grid.Column="1" Content="-" Tag="2:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="2" Grid.Column="2" Content="+" Tag="2:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="J4"/>
                                        <Button    Grid.Row="3" Grid.Column="1" Content="-" Tag="3:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="3" Grid.Column="2" Content="+" Tag="3:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="J5"/>
                                        <Button    Grid.Row="4" Grid.Column="1" Content="-" Tag="4:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="4" Grid.Column="2" Content="+" Tag="4:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="J6"/>
                                        <Button    Grid.Row="5" Grid.Column="1" Content="-" Tag="5:-1" Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                        <Button    Grid.Row="5" Grid.Column="2" Content="+" Tag="5:1"  Style="{StaticResource JogBtn}" PreviewMouseLeftButtonDown="JogBtn_Down" PreviewMouseLeftButtonUp="JogBtn_Up" MouseLeave="JogBtn_Leave"/>
                                    </Grid>
                                </GroupBox>
                                <Button Content="Reset to Home" Padding="8,4" Click="BtnResetHome_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ====== Auto Mode (TCP pose input) ====== -->
                    <TabItem Header="Auto">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <GroupBox Header="Target TCP Pose" Margin="0,0,0,12">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X"  VerticalAlignment="Center"/>
                                        <TextBox  Grid.Row="0" Grid.Column="1" Name="TxtPoseX"  Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Y"  VerticalAlignment="Center"/>
                                        <TextBox  Grid.Row="1" Grid.Column="1" Name="TxtPoseY"  Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Z"  VerticalAlignment="Center"/>
                                        <TextBox  Grid.Row="2" Grid.Column="1" Name="TxtPoseZ"  Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="A" VerticalAlignment="Center" ToolTip="Rotation about X axis"/>
                                        <TextBox  Grid.Row="3" Grid.Column="1" Name="TxtPoseA" Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="°"  VerticalAlignment="Center" Margin="4,0,0,0"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="B" VerticalAlignment="Center" ToolTip="Rotation about Y axis"/>
                                        <TextBox  Grid.Row="4" Grid.Column="1" Name="TxtPoseB" Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="°"  VerticalAlignment="Center" Margin="4,0,0,0"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="C" VerticalAlignment="Center" ToolTip="Rotation about Z axis"/>
                                        <TextBox  Grid.Row="5" Grid.Column="1" Name="TxtPoseC" Text="0.000" Margin="4" FontFamily="Consolas"/>
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="°"  VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                </GroupBox>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Copy Current" Margin="0,0,4,0" Padding="8,4" Click="BtnCopyCurrentPose_Click"/>
                                    <Button Grid.Column="1" Content="Move To"      Margin="4,0,0,0" Padding="8,4" Click="BtnMoveTo_Click"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ====== Drag Mode ====== -->
                    <TabItem Header="Drag">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <GroupBox Header="Drag Teach" Margin="0,0,0,12">
                                    <StackPanel Margin="10">
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Text="Drag mode: use the mouse to drag the TCP or a joint to pose the robot in real time."/>
                                        <ToggleButton Name="TglDragEnable" Content="Enable Drag" Padding="8,4" Margin="0,0,0,8"
                                                      Checked="TglDragEnable_Changed" Unchecked="TglDragEnable_Changed"/>
                                        <TextBlock Text="Drag Target:" Margin="0,4,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Name="RbDragTcp"   Content="TCP"   IsChecked="True" Margin="0,0,12,0" GroupName="DragTarget"/>
                                            <RadioButton Name="RbDragJoint" Content="Joint"                  GroupName="DragTarget"/>
                                        </StackPanel>
                                        <TextBlock Text="Gizmo:" Margin="0,8,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Name="RbGizmoTranslate" Content="Translate" IsChecked="True" Margin="0,0,12,0" GroupName="Gizmo"/>
                                            <RadioButton Name="RbGizmoRotate"    Content="Rotate"                     GroupName="Gizmo"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>

            <Border Grid.Column="1" Margin="8" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#2E2E2E">
                <wfi:WindowsFormsHost Name="WinFormsHost" Margin="0">
                    <wf:Panel x:Name="DesignPlaceholder" BackColor="#2E2E2E" />
                </wfi:WindowsFormsHost>
            </Border>
        </Grid>
    </DockPanel>
</Window>
